# Copy to .env in your workspace or a parent folder (never commit .env).
# Precedence: process environment > .env > codegen.toml (for keys also read from env).

# Required for `codegen run` (OpenAI)
OPENAI_API_KEY=

# Optional — OpenAI
# Base URL must include https:// or http:// (e.g. https://api.openai.com/v1)
OPENAI_BASE_URL=
OPENAI_MODEL=

# Optional — proxy for HTTPS (must be a full URL; not just host:port)
# HTTPS_PROXY=http://127.0.0.1:7890

# Optional — path to TOML when not using --config / workspace discovery
CODEGEN_CONFIG=

# Optional — override TOML / defaults
CODEGEN_MAX_ITERATIONS=
CODEGEN_MAX_WALL_CLOCK_SECONDS=
CODEGEN_AGENTS_MD=

# Optional — JSONL structured logs (stderr, -, or file path)
CODEGEN_STRUCTURED_LOG=
